<div class="bg-light dark:bg-transparent min-vh-100 d-flex flex-row align-items-center">
  <c-container breakpoint="md">
    <c-row class="justify-content-center">
      <c-col lg="6" xl="5">
        <c-card class="p-4">
          <c-card-body>
            <form cForm>
              <h1>Avantti Comprova</h1>
              <p class="text-body-secondary">Informe seus dados de acesso</p>

              <c-input-group class="mb-3">
                <span cInputGroupText>
                  <svg cIcon name="cilUser"></svg>
                </span>
                <input
                  cFormControl
                  type="usuario"
                  placeholder="E-mail"
                  autoComplete="username"
                  [(ngModel)]="usuario"
                  name="usuario"
                />
              </c-input-group>

              <c-input-group class="mb-4">
                <span cInputGroupText>
                  <svg cIcon name="cilLockLocked"></svg>
                </span>
                <input
                  cFormControl
                  type="password"
                  placeholder="Senha"
                  autoComplete="current-password"
                  [(ngModel)]="senha"
                  name="senha"
                />
              </c-input-group>

              <div *ngIf="mensagemErro" class="text-danger mb-3">
                {{ mensagemErro }}
              </div>

              <button
                cButton
                class="px-4 w-100"
                color="primary"
                type="button"
                [disabled]="carregando"
                (click)="entrar()">
                {{ carregando ? 'Entrando...' : 'Entrar' }}
              </button>
            </form>
          </c-card-body>
        </c-card>
      </c-col>
    </c-row>
  </c-container>
</div>
